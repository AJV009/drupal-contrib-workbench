# Issue workspaces (large, per-issue DDEV envs + artifacts)
DRUPAL_ISSUES/*
!DRUPAL_ISSUES/.gitkeep

# Temp workspace
TEMP/*
!TEMP/.gitkeep

# Secrets
*.key

# Python
__pycache__/
*.pyc

# Runtime
tui.json

# Claude session data
.claude/projects/

# Contribution artifacts (generated per-issue)
.drupal-contribute-fix/

# Beads / Dolt files (added by bd init)
.dolt/
*.db
.beads-credential-key
